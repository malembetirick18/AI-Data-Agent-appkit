DATABRICKS_HOST=https://...
DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME=my-data-ai-assistant
DATABRICKS_GENIE_SPACE_ID_GEO=...
DATABRICKS_GENIE_SPACE_ID_CLOSING=...
FLASK_RUN_HOST=0.0.0.0

# GenUI DSPy plugin
GENUI_PYTHON_EXECUTABLE=python
GENUI_DSPY_RUNNER_PATH=server/python/dspy_genui_runner.py
GENIE_KNOWLEDGE_STORE_PATH=catalog_schemas_description/genie_knowledge_store.json
GENUI_DSPY_TIMEOUT_MS=60000
GENUI_DSPY_MODEL=openai/gpt-4o-mini
GENUI_DSPY_API_BASE=
GENUI_DSPY_API_KEY=
GENUI_DSPY_TEMPERATURE=0.1
GENUI_DEFAULT_RENDER_MODE=combo
GENUI_SKIP_PYTHON_DEPS_CHECK=false
GENUI_AUTO_INSTALL_PYTHON_DEPS=false
GENUI_DSPY_REQUIREMENTS_PATH=server/python/requirements-dspy.txt

# MLflow tracing
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=genui-dspy

# Semantic layer FastAPI server
SEMANTIC_LAYER_API_URL=http://localhost:8001/api
